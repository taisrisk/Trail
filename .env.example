# Trail local configuration
# Copy this file to .env.local for local-only settings.

# Optional: where a future Trail node should store local runtime data.
TRAIL_HOME=~/.trail

# Erme Pass password-manager vault storage. Docker defaults this to /data/pass.
ERME_PASS_HOME=~/.erme/pass

# Public product/subdomain map used by docs, deploys, and Docker.
PUBLIC_ERME_DOMAIN=erme.onl
PUBLIC_EMAIL_DOMAIN=email.erme.onl
PUBLIC_PASS_DOMAIN=pass.erme.onl
PUBLIC_SYNC_DOMAIN=sync.erme.onl

# Optional: local model endpoint for future watcher runner.
OLLAMA_BASE_URL=http://localhost:11434

# Never commit real connector tokens, SMTP passwords, private keys, recovery phrases, or mailbox data.
