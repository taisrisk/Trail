{
  "name": "trail",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:smoke": "node scripts/docker-smoke.mjs",
    "trail:node": "node scripts/trail-local-server.mjs",
    "trail:health": "node -e \"fetch('http://127.0.0.1:8787/health').then(r=>r.json()).then(console.log).catch(err=>{console.error(err.message); process.exit(1)})\""
  },
  "dependencies": {
    "hono": "^4.12.25",
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22.19.20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
